# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Environment files
.env
.env.*
!.env.example

# Local kubeconfig and generated Kubernetes secret material
.kube/
kubeconfig*
*.kubeconfig
KUBE_CONFIG_DATA*
k8s/**/*-secret.yaml
!k8s/**/*-secret.example.yaml
!k8s/**/app-secret.example.yaml
!k8s/**/postgres-secret.example.yaml

# Local build artifacts
dist/
build/
*.egg-info/

# Editor and OS files
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Logs and generated evidence
*.tmp
*.bak

# Terraform
**/.terraform/
**/.terraform.lock.hcl
**/terraform.tfstate
**/terraform.tfstate.*
**/terraform.tfvars
**/crash.log
**/crash.*.log
**/*.tfplan
**/*.tfstate.backup
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json

# Keep evidence placeholders, but ignore large captured media by default.
evidence/screenshots/*.png
evidence/screenshots/*.jpg
evidence/screenshots/*.jpeg
evidence/screenshots/*.webp
!evidence/screenshots/*placeholder.md
